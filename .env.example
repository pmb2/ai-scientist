# AI Scientist Environment Configuration
# Copy to .env in the AI-Scientist root directory

# Required: API key for OpenRouter (used for LLM calls)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Default model to use
AI_SCIENTIST_MODEL=openrouter/google/gemma-4-31b-it:free

# Optional: Semantic Scholar API Key (for higher throughput literature search)
# S2_API_KEY=your_s2_key_here

# Optional: OpenAlex email (alternative to Semantic Scholar)
# OPENALEX_MAIL_ADDRESS=your_email@example.com
